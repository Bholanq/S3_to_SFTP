S3_BUCKET        = "your-bucket-name"
S3_PREFIX        = "incoming/"           # S3 folder to download from (use "" for root)
 
SFTP_HOST        = "sftp.example.com"
SFTP_PORT        = 22
SFTP_USERNAME    = "sftp_user"
SFTP_PASSWORD    = ""                    # Leave empty if using key-based auth
SFTP_PRIVATE_KEY = ""                    # Path to .ppk file, e.g. r"C:\keys\mykey.ppk"
SFTP_REMOTE_DIR  = "/upload/"            # Destination folder on SFTP server
 
WINSCP_EXE       = r"C:\Program Files (x86)\WinSCP\WinSCP.com"  # Path to WinSCP CLI
LOG_FILE         = "s3_to_sftp_transfer.log"